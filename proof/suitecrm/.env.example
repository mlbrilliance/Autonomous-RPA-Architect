# proof/suitecrm/.env.example — copy to proof/suitecrm/.env before running
# docker compose --env-file .env up -d
#
# The real .env is gitignored. Pick strong, unique passwords — even for a
# local-only instance — so nothing matches a dictionary scan.

# MariaDB
SC_DB_NAME=suitecrm
SC_DB_USER=suitecrm
SC_DB_PASSWORD=change_me_before_running
SC_DB_ROOT_PASSWORD=change_me_too

# SuiteCRM admin
SC_ADMIN_USER=admin
SC_ADMIN_PASSWORD=change_me_strong_please
SC_ADMIN_EMAIL=admin@example.test

# Ports (override if you need to avoid collisions with other services)
SC_HTTP_PORT=8080
SC_HTTPS_PORT=8443

# Optional: the hostname SuiteCRM uses in generated links — set to your
# cloudflared tunnel hostname if exposing publicly.
# SUITECRM_HOST=indie-beaver-itunes-updating.trycloudflare.com
