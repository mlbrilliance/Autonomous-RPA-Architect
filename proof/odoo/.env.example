# proof/odoo/.env.example — copy to proof/odoo/.env before running
# docker compose --env-file .env up -d
#
# The real .env is gitignored. Pick any password you want for the local
# Postgres that backs the demo Odoo. These credentials only exist inside
# the Docker network on your laptop — do not reuse them anywhere else.

OD_DB_USER=odoo
OD_DB_PASSWORD=change_me_before_running
