          "parameters": {
            "url": "https://the-internet.herokuapp.com/inputs"
          },
          "uncertainty": null,
          "substeps": [],
          "description": "Type a number into the input field"
        },
        {
          "id": "S005",
          "type": "ui_flow",
          "system_ref": "TheInternet",
          "actions": [
            {
              "action": "type_into",
              "target": "Input Field",
              "value": "Hello World",
              "selector_hint": null,
              "confidence": 0.5
