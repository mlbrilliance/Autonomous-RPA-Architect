{
  "process_name": "WebInteractionAutomation",
  "process_type": "transactional",
  "description": "Automated interaction with the-internet.herokuapp.com test pages \u2014 clicks buttons, toggles checkboxes, selects dropdowns, types into inputs, and reads text results. Designed as a REFramework queue performer that processes each page interaction as a transaction item.",
  "systems": [
    {
      "name": "TheInternet",
      "type": "web",
      "url": "https://the-internet.herokuapp.com",
      "login_required": false
    }
  ],
  "credentials": [],
  "transactions": [
    {
      "name": "InteractWithTestPages",
      "input_contract": null,
      "output_contract": null,
      "steps": [
        {
          "id": "S001",
          "type": "navigate",
          "system_ref": "TheInternet",
          "actions": [
            {
              "action": "click",
              "target": "Add Element",
              "value": null,
              "selector_hint": null,
              "confidence": 0.5
            }
          ],
          "parameters": {
            "url": "https://the-internet.herokuapp.com/add_remove_elements/"
          },
          "uncertainty": null,
          "substeps": [],
          "description": "Click the Add Element button on the add/remove elements page"
        },
        {
          "id": "S002",
          "type": "ui_flow",
          "system_ref": "TheInternet",
          "actions": [
            {
              "action": "check",
              "target": "checkbox 1",
              "value": null,
              "selector_hint": null,
              "confidence": 0.5
            },
            {
              "action": "check",
              "target": "checkbox 2",
              "value": null,
              "selector_hint": null,
              "confidence": 0.5
            }
          ],
          "parameters": {
            "url": "https://the-internet.herokuapp.com/checkboxes"
          },
          "uncertainty": null,
          "substeps": [],
          "description": "Toggle checkboxes on the checkboxes page"
        },
        {
          "id": "S003",
          "type": "ui_flow",
          "system_ref": "TheInternet",
          "actions": [
            {
              "action": "select_item",
              "target": "Dropdown",
              "value": "Option 1",
