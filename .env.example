# ─── LLM Provider Keys ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # Anthropic API key for Claude models
# OPENAI_API_KEY=sk-...               # OpenAI API key (if using OpenAI provider)

# ─── UiPath Cloud Configuration ──────────────────────────────────────────────
# UIPATH_URL=https://cloud.uipath.com # UiPath Orchestrator base URL
# UIPATH_TENANT_ID=                   # UiPath tenant/organization ID
# UIPATH_CLIENT_ID=                   # OAuth client ID for UiPath app
# UIPATH_CLIENT_SECRET=               # OAuth client secret for UiPath app
# UIPATH_FOLDER=                      # UiPath Orchestrator folder name

# ─── LLM Settings ────────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic              # Options: anthropic, openai, uipath_gateway
# LLM_MODEL=claude-sonnet-4-20250514    # Model name to use for generation

# ─── RAG / Knowledge Base ────────────────────────────────────────────────────
# RAG_PERSIST_DIR=./knowledge/.chroma  # ChromaDB persistence directory

# ─── Browser Selector Harvesting ──────────────────────────────────────────────
# HARVEST_ENABLED=false                # Enable live browser harvesting
# HARVEST_HEADLESS=true                # Run browser in headless mode
# HARVEST_TIMEOUT_MS=30000             # Navigation timeout (ms)
# HARVEST_MAX_ELEMENTS_PER_PAGE=200    # Max elements to harvest per page
# HARVEST_CRED_INVOICEPORTAL_USER=     # Per-system credentials for login
# HARVEST_CRED_INVOICEPORTAL_PASS=     #   (format: HARVEST_CRED_{SYSTEM}_USER/PASS)
# HARVEST_CRED_ERPSYSTEM_USER=
# HARVEST_CRED_ERPSYSTEM_PASS=

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                       # Logging level: DEBUG, INFO, WARNING, ERROR
